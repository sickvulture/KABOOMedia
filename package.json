{
  "name": "kaboomedia",
  "version": "1.0.0",
  "description": "Decentralized encrypted social media platform",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "test": "jest",
    "update:deps": "bash scripts/update-dependencies.sh",
    "audit:fix": "npm audit fix && cd client && npm audit fix",
    "security:check": "npm audit --audit-level=moderate"
  },
  "keywords": [
    "decentralized",
    "encrypted",
    "social-media",
    "p2p",
    "privacy"
  ],
  "author": "Chris Smith with Claude AI",
  "license": "GPL-3.0",
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.8.0",
    "node-forge": "^1.3.1",
    "ws": "^8.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "rate-limiter-flexible": "^5.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
