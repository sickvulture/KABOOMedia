    "helmet": "^7.1.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^8.7.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "ws": "^8.14.2",
    "node-forge": "^1.3.1",
