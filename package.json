{
  "name": "kaboomedia",
  "version": "1.0.0",
  "description": "Decentralized encrypted social media platform",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "test": "jest"
  },
  "keywords": [
    "decentralized",
    "encrypted",
    "social-media",
    "p2p",
    "privacy"
  ],
  "author": "Chris Smith with Claude AI",
  "license": "GPL-3.0",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "crypto": "^1.0.1",
    "node-forge": "^1.3.1",
    "ws": "^8.13.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "rate-limiter-flexible": "^2.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "jest": "^29.6.2"
  }
}
