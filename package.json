{
  "name": "kaboomedia-phase3",
  "version": "1.2.0",
  "description": "KABOOMedia Phase 3 - Advanced Decentralized Social Media Platform with Media Sharing, Comments, and Real-time Chat",
  "main": "server-phase3.js",
  "scripts": {
    "start": "node server-phase3.js",
    "dev": "nodemon server-phase3.js --ignore 'kaboomedia/' --ignore 'public/'",
    "setup": "node setup.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rm -rf kaboomedia/ .env",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "migrate": "node scripts/migrate-to-phase3.js",
    "lint": "eslint *.js --fix",
    "format": "prettier --write *.js *.json *.md",
    "docker:build": "docker build -t kaboomedia-phase3 .",
    "docker:run": "docker run -p 8080:8080 -p 8081:8081 -p 8082:8082 kaboomedia-phase3"
  },
  "keywords": [
    "decentralized",
    "social-media",
    "p2p",
    "encryption",
    "privacy",
    "blockchain-free",
    "self-hosted",
    "media-sharing",
    "real-time-chat",
    "comments",
    "reactions"
  ],
  "author": "Chris Smith with Claude AI",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaboomedia/kaboomedia-phase3.git"
  },
  "bugs": {
    "url": "https://github.com/kaboomedia/kaboomedia-phase3/issues"
  },
  "homepage": "https://github.com/kaboomedia/kaboomedia-phase3#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^8.7.0",
    "bcrypt": "^5.1.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "ws": "^8.14.2",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "fluent-ffmpeg": "^2.1.2",
    "qrcode": "^1.5.3",
    "node-fetch": "^3.3.2",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "crypto-js": "^4.2.0",
    "mime-types": "^2.1.35",
    "sanitize-html": "^2.11.0",
    "validator": "^13.11.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.9.4",
    "typescript": "^5.3.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2",
    "node-canvas-webgl": "^0.2.0",
    "sharp-ico": "^0.1.5"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/kaboomedia"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.js",
      "!setup.js",
      "!scripts/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "nodemonConfig": {
    "ignore": [
      "kaboomedia/",
      "public/",
      "coverage/",
      "*.log"
    ],
    "ext": "js,json",
    "env": {
      "NODE_ENV": "development"
    },
    "delay": 1000
  }
}
