# Server Configuration
PORT=5000
NODE_ENV=development

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-very-secure-jwt-secret-key-change-this-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-for-file-storage

# Database (if using external database)
# DATABASE_URL=mongodb://localhost:27017/kaboomedia
# REDIS_URL=redis://localhost:6379

# File Storage Configuration
MAX_FILE_SIZE=104857600
STORAGE_PATH=./storage
TEMP_PATH=./temp
MAX_STORAGE_SIZE=10737418240

# Network Configuration
MAX_PEERS_PER_NETWORK=100
NETWORK_TIMEOUT=30000
PEER_DISCOVERY_INTERVAL=60000
CONNECTION_RETRY_ATTEMPTS=3

# Security Settings
BCRYPT_ROUNDS=12
TOKEN_EXPIRY=24h
SESSION_TIMEOUT=86400000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
FILE_UPLOAD_RATE_LIMIT=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5
LOG_RETENTION_DAYS=30

# Monitoring
ENABLE_METRICS=false
METRICS_PORT=9090

# Development
DEBUG=kaboomedia:*
DEVELOPMENT_MODE=true

# SSL/TLS (for production)
# SSL_KEY_PATH=/path/to/private-key.pem
# SSL_CERT_PATH=/path/to/certificate.pem
# SSL_CA_PATH=/path/to/ca-certificate.pem

# WebRTC Configuration (for P2P features)
# ICE_SERVERS=stun:stun.l.google.com:19302,turn:your-turn-server.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-password

# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Analytics (optional)
# ANALYTICS_ENABLED=false
# ANALYTICS_ENDPOINT=https://your-analytics-server.com

# Backup Configuration
# BACKUP_ENABLED=false
# BACKUP_INTERVAL=86400000
# BACKUP_RETENTION=604800000
# BACKUP_PATH=./backups
