# Server Configuration
PORT=5000
NODE_ENV=development

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-very-secure-jwt-secret-key-change-this-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-for-file-storage

# File Storage Configuration
MAX_FILE_SIZE=104857600
STORAGE_PATH=./storage
TEMP_PATH=./temp
MAX_STORAGE_SIZE=10737418240

# Network Configuration
MAX_PEERS_PER_NETWORK=100
NETWORK_TIMEOUT=30000
PEER_DISCOVERY_INTERVAL=60000
CONNECTION_RETRY_ATTEMPTS=3

# Security Settings
BCRYPT_ROUNDS=12
TOKEN_EXPIRY=24h
SESSION_TIMEOUT=86400000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
FILE_UPLOAD_RATE_LIMIT=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5
LOG_RETENTION_DAYS=30
